# MapTiler API Key (Get free key at https://www.maptiler.com/cloud/)
# Required — powers the vector base maps (Ruas, Claro, Satélite, etc.)
VITE_MAPTILER_KEY=your_maptiler_key_here

# Stadia Maps API Key (Get free key at https://stadiamaps.com/)
# Optional — only the "Aquarela" (Stamen Watercolor) base map uses it.
# Works key-less on localhost; needed only for the deployed site (authorize the domain).
VITE_STADIA_KEY=your_stadia_key_here

# Application Configuration
VITE_APP_TITLE=Estado Novo - Mapeamento dos Apelos
VITE_APP_DESCRIPTION=Mapa interativo dos apelos de desapropriação no Rio de Janeiro

